# Database
DATABASE_URL="postgresql://user:password@localhost:5432/nouri"

# Auth
# Set NEXTAUTH_URL to match the port your dev server runs on (e.g., 3003 if 3000 is occupied)
NEXTAUTH_URL="http://localhost:3003"
NEXTAUTH_SECRET="generate-a-secret-here"

# GitHub OAuth (for dev authentication)
GITHUB_ID=""
GITHUB_SECRET=""

# AI Providers
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_GEMINI_API_KEY=""

# Azure Blob Storage
AZURE_STORAGE_CONNECTION_STRING=""
AZURE_STORAGE_CONTAINER_NAME="nouri-images"